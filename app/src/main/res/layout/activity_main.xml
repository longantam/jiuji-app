<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#171614">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#171614">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="九極排盤"
            android:textColor="#C9A227"
            android:textSize="22sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvTabTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="時空排盤"
            android:textColor="#888888"
            android:textSize="13sp"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="56dp">

        <!-- TAB 1: 排盤 -->
        <ScrollView android:id="@+id/pagePaipan"
            android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="#1C1B19" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="輸入日期與時間" android:textColor="#888888" android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="年份（公曆）" android:textColor="#888888" android:textSize="12sp"/>
                            <EditText android:id="@+id/etYear" android:layout_width="match_parent"
                                android:layout_height="48dp" android:background="#2A2926"
                                android:textColor="#CDCCCA" android:inputType="number"
                                android:hint="2026" android:textColorHint="#555" android:padding="10dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="月份（公曆）" android:textColor="#888888" android:textSize="12sp"/>
                            <EditText android:id="@+id/etMonth" android:layout_width="match_parent"
                                android:layout_height="48dp" android:background="#2A2926"
                                android:textColor="#CDCCCA" android:inputType="number"
                                android:hint="6" android:textColorHint="#555" android:padding="10dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="日期（公曆）" android:textColor="#888888" android:textSize="12sp"
                        android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/etDay" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="#2A2926"
                        android:textColor="#CDCCCA" android:inputType="number"
                        android:hint="15" android:textColorHint="#555" android:padding="10dp"/>
                    <TextView android:id="@+id/tvLunar" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:padding="12dp"
                        android:background="#2A3830" android:textColor="#9ECFCE"
                        android:textSize="14sp" android:layout_marginTop="8dp" android:visibility="gone"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="小時（選填）" android:textColor="#888888" android:textSize="12sp"
                        android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/etHour" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="#2A2926"
                        android:textColor="#CDCCCA" android:inputType="number"
                        android:hint="10" android:textColorHint="#555" android:padding="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="分鐘（選填）" android:textColor="#888888" android:textSize="12sp"
                        android:layout_marginTop="8dp"/>
                    <EditText android:id="@+id/etMinute" android:layout_width="match_parent"
                        android:layout_height="48dp" android:background="#2A2926"
                        android:textColor="#CDCCCA" android:inputType="number"
                        android:hint="36" android:textColorHint="#555" android:padding="10dp"/>
                    <Button android:id="@+id/btnCalc" android:layout_width="match_parent"
                        android:layout_height="52dp" android:text="排　　盤"
                        android:textColor="#1A1814" android:textSize="17sp" android:textStyle="bold"
                        android:backgroundTint="#C9A227" android:layout_marginTop="12dp"/>
                    <TextView android:id="@+id/tvError" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:textColor="#FF6B6B"
                        android:textSize="13sp" android:layout_marginTop="8dp" android:visibility="gone"/>
                </LinearLayout>

                <!-- RESULTS -->
                <LinearLayout android:id="@+id/resultSection"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:layout_marginTop="12dp" android:visibility="gone">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#2A2926" android:padding="14dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⊙ 九極排列" android:textColor="#888888" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvSummary" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#C9A227"
                            android:textSize="13sp" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="天極·年極 / 地極·月極" android:textColor="#888888"
                        android:textSize="11sp" android:layout_marginTop="12dp" android:layout_marginBottom="6dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:id="@+id/tvNianD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="天極·年" android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvNian" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="26sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvYueD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="地極·月" android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvYue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="26sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="6dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:id="@+id/tvDaDuanD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvDaDuan" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="20sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvZhDuanD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvZhDuan" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="20sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#1C1B19" android:padding="12dp" android:orientation="vertical" android:layout_marginTop="6dp">
                        <TextView android:id="@+id/tvXiDuanD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#888888" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvXiDuan" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#C9A227" android:textSize="20sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="人極·日極 / 時極 / 刻極" android:textColor="#888888"
                        android:textSize="11sp" android:layout_marginTop="12dp" android:layout_marginBottom="6dp"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:id="@+id/tvRiD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="人極·日" android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvRi" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="26sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvShiD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="時辰" android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvShi" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="26sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="6dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                            <TextView android:id="@+id/tvDaKeD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvDaKe" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="20sp" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:background="#1C1B19" android:padding="12dp" android:orientation="vertical">
                            <TextView android:id="@+id/tvXiaoKeD" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#888888" android:textSize="11sp"/>
                            <TextView android:id="@+id/tvXiaoKe" android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="#C9A227" android:textSize="20sp" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View android:layout_width="match_parent" android:layout_height="16dp"/>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- TAB 2: 子午流注 -->
        <ScrollView android:id="@+id/pageZiwu"
            android:layout_width="match_parent" android:layout_height="match_parent" android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:id="@+id/ziwuEmptyHint"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center" android:padding="40dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="請先在「時空排盤」頁輸入日期與小時，再按「排盤」"
                        android:textColor="#888888" android:textSize="14sp" android:gravity="center"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/ziwuContent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:visibility="gone">
                    <TextView android:id="@+id/tvZiwuContext" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:background="#1A2E2E"
                        android:padding="14dp" android:textColor="#9ECFCE" android:textSize="14sp"
                        android:layout_marginBottom="12dp"/>
                    <!-- 納子法 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#1C1B19" android:padding="16dp" android:orientation="vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▌ 納子法（逢時取穴）" android:textColor="#C9A227"
                            android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvNaziMeridian" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="#CDCCCA"
                            android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="逢時可取五輸穴" android:textColor="#888888" android:textSize="11sp"/>
                        <TextView android:id="@+id/tvNaziAllPoints" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textColor="#C9A227"
                            android:textSize="15sp" android:layout_marginBottom="10dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="補穴（虛症）" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaziBu" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#9ECFCE" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="瀉穴（實症）" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaziXie" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#FF8080" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="本穴/原穴" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaziBen" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#CDCCCA" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                    <!-- 納甲法 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#1C1B19" android:padding="16dp" android:orientation="vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▌ 納甲法（按日干時干）" android:textColor="#C9A227"
                            android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="8dp">
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="主穴" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaJiaMain" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#C9A227" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical" android:layout_marginEnd="6dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="合日互用" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaJiaHe" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#9ECFCE" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                                android:background="#252422" android:padding="10dp" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="返本還原" android:textColor="#888888" android:textSize="10sp"/>
                                <TextView android:id="@+id/tvNaJiaYuan" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:textColor="#CDCCCA" android:textSize="16sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                        <TextView android:id="@+id/tvNaJiaNote" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#888888" android:textSize="11sp"/>
                    </LinearLayout>
                    <!-- 靈龜八法 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#1C1B19" android:padding="16dp" android:orientation="vertical" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▌ 靈龜八法（奇經八穴）" android:textColor="#C9A227"
                            android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvLingGui" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#CDCCCA"
                            android:textSize="14sp" android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                    <!-- 飛騰八法 -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:background="#1C1B19" android:padding="16dp" android:orientation="vertical" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="▌ 飛騰八法（按時干）" android:textColor="#C9A227"
                            android:textSize="14sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                        <TextView android:id="@+id/tvFeiteng" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#CDCCCA" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <!-- BOTTOM TAB BAR -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
        android:layout_gravity="bottom" android:background="#1C1B19"
        android:orientation="horizontal" android:elevation="8dp">
        <LinearLayout android:id="@+id/tabPaipan"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⊙" android:textSize="18sp" android:textColor="#C9A227"/>
            <TextView android:id="@+id/tabPaipanLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="時空排盤"
                android:textSize="10sp" android:textColor="#C9A227"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/tabZiwu"
            android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"
            android:gravity="center" android:orientation="vertical"
            android:clickable="true" android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="針" android:textSize="18sp" android:textColor="#4A4840"/>
            <TextView android:id="@+id/tabZiwuLabel" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="子午流注"
                android:textSize="10sp" android:textColor="#4A4840"/>
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
